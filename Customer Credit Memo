SELECT 
    COALESCE(RM.CUSTNMBR, RMOPEN.CUSTNMBR) AS [Customer No],
    COALESCE(C.CUSTNAME, COPEN.CUSTNAME)   AS [Customer Name],

    COALESCE(RM.DOCDATE, RMOPEN.DOCDATE)   AS [Posting Date],
    'Credit Memo'                          AS [Document Type],

    COALESCE(RM.DOCNUMBR, RMOPEN.DOCNUMBR) AS [Document No],

    COALESCE(RM.ORTRXAMT, RMOPEN.ORTRXAMT) AS [Amount],
    COALESCE(RM.CURTRXAM, RMOPEN.CURTRXAM) AS [Remaining Amount],

    CASE 
        WHEN COALESCE(RM.CURTRXAM, RMOPEN.CURTRXAM) = 0 THEN 'Closed'
        ELSE 'Open'
    END AS [Status],

    -- NEW COLUMNS
    APP.AppliedInvoiceNo,
    APP.AppliedAmount

FROM SWFM.dbo.RM30101 RM WITH (NOLOCK)

LEFT JOIN SWFM.dbo.RM00101 C WITH (NOLOCK)
    ON RM.CUSTNMBR = C.CUSTNMBR

FULL OUTER JOIN SWFM.dbo.RM20101 RMOPEN WITH (NOLOCK)
    ON RM.DOCNUMBR = RMOPEN.DOCNUMBR

LEFT JOIN SWFM.dbo.RM00101 COPEN WITH (NOLOCK)
    ON RMOPEN.CUSTNMBR = COPEN.CUSTNMBR

-- APPLY DATA (AGGREGATED)
LEFT JOIN (
    SELECT 
        APFRDCNM,
        MAX(APTODCNM) AS AppliedInvoiceNo,
        SUM(APPTOAMT) AS AppliedAmount
    FROM SWFM.dbo.RM20201 WITH (NOLOCK)
    WHERE APPTOAMT <> 0
    GROUP BY APFRDCNM
) APP
ON COALESCE(RM.DOCNUMBR, RMOPEN.DOCNUMBR) = APP.APFRDCNM

WHERE 
    (RM.RMDTYPAL = 7 OR RMOPEN.RMDTYPAL = 7)

AND COALESCE(RM.DOCDATE, RMOPEN.DOCDATE) >= '2019-01-01'
AND COALESCE(RM.DOCDATE, RMOPEN.DOCDATE) <  '2026-01-01'

ORDER BY [Document No];

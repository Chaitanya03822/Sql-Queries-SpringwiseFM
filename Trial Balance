
SELECT 
    -- Combine account segments
    RTRIM(GL.ACTNUMBR_1) + '-' +
    RTRIM(GL.ACTNUMBR_2) + '-' +
    RTRIM(GL.ACTNUMBR_3) + '-' +
    RTRIM(GL.ACTNUMBR_4) + '-' +
    RTRIM(GL.ACTNUMBR_5) + '-' +
    RTRIM(GL.ACTNUMBR_6) AS [Account No],

    GL.ACTDESCR AS [Account Name],

    SUM(T.DEBITAMT) AS [Total Debit],
    SUM(T.CRDTAMNT) AS [Total Credit],
    SUM(T.DEBITAMT - T.CRDTAMNT) AS [Balance]

FROM (
    SELECT ACTINDX, DEBITAMT, CRDTAMNT, TRXDATE FROM SWFM.dbo.GL20000
    UNION ALL
    SELECT ACTINDX, DEBITAMT, CRDTAMNT, TRXDATE FROM SWFM.dbo.GL30000
) T

INNER JOIN SWFM.dbo.GL00100 GL 
    ON T.ACTINDX = GL.ACTINDX

WHERE T.TRXDATE <= '2019-12-31'

GROUP BY 
    GL.ACTNUMBR_1,
    GL.ACTNUMBR_2,
    GL.ACTNUMBR_3,
    GL.ACTNUMBR_4,
    GL.ACTNUMBR_5,
    GL.ACTNUMBR_6,
    GL.ACTDESCR

HAVING SUM(T.DEBITAMT - T.CRDTAMNT) <> 0

ORDER BY 
    GL.ACTNUMBR_1,
    GL.ACTNUMBR_2;
